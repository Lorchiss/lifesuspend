[Unit]
Description=lifesuspend daemon (overlay Game of Life)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
Environment=XDG_RUNTIME_DIR=%t
Environment=HOME=%h
Environment=LD_PRELOAD=/usr/lib/libgtk4-layer-shell.so.0
ExecStart=%h/.local/bin/lifesuspendd --config %h/.config/lifesuspend/config.toml --socket %h/.cache/lifesuspend/socket
Restart=on-failure
RestartSec=1
TimeoutStopSec=5

[Install]
WantedBy=default.target
